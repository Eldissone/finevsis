# =============================================
# FINEVSIS — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha
# =============================================

# PostgreSQL
POSTGRES_USER=finevsis
POSTGRES_PASSWORD=finevsis_secret
POSTGRES_DB=finevsis_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://finevsis:finevsis_secret@localhost:5432/finevsis_db

# Backend
JWT_SECRET=troca_este_valor_por_um_segredo_forte
NODE_ENV=development
PORT=3001

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Frontend
VITE_API_URL=http://localhost:3001
VITE_AI_URL=http://localhost:8000

# Redis
REDIS_URL=redis://localhost:6379

# APIs de Coleta (opcionais)
SERPAPI_KEY=
TWITTER_BEARER_TOKEN=
NEWSAPI_KEY=
